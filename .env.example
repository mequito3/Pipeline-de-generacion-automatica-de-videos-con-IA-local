# ─── Shorts Factory — Variables de entorno ───────────────────────────────────
# Copiar este archivo a .env y rellenar los valores reales
# NUNCA subir .env a git (ya está en .gitignore)

# ─── YouTube (Selenium) ──────────────────────────────────────────────────────
YOUTUBE_EMAIL=tucorreo@gmail.com
YOUTUBE_PASSWORD=tu_password_aqui

# ─── Branding del canal ───────────────────────────────────────────────────────
CHANNEL_NAME=NOMBRE DEL CANAL

# ─── Ollama (LLM local) ───────────────────────────────────────────────────────
# Modelos recomendados (de mejor a peor para este caso):
#   llama3        → mejor calidad de JSON, algo lento
#   mistral       → buen balance calidad/velocidad
#   gemma2        → rápido, JSON consistente
#   phi3          → más liviano, para PCs sin mucha RAM
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ─── Pexels (stock videos gratuitos — recomendado para más vistas) ───────────
# Regístrate gratis: https://www.pexels.com/api/
# 200 solicitudes/hora, 20,000/mes — suficiente para el pipeline
PEXELS_API_KEY=tu_clave_pexels_aqui
# Activa el uso de Pexels en vez de Stable Diffusion (true/false)
USE_PEXELS=true

# ─── Stable Diffusion ────────────────────────────────────────────────────────
# "auto"    → detecta automáticamente A1111 o ComfyUI
# "a1111"   → forzar Automatic1111 (http://localhost:7860)
# "comfyui" → forzar ComfyUI (cambiar puerto si es distinto al default)
SD_BACKEND=auto
SD_A1111_URL=http://localhost:7860
SD_COMFYUI_URL=http://localhost:8000

# SD_STEPS: más pasos = más calidad, más lento
#   15 → rápido (~20s/img en GPU media)
#   20 → balance recomendado (~30s/img)
#   30 → alta calidad (~45s/img)
SD_STEPS=20
SD_CFG_SCALE=7.0

# ─── Video ────────────────────────────────────────────────────────────────────
# TTS_VOICE_RATE: palabras por minuto (175 = natural, 150 = lento, 200 = rápido)
TTS_VOICE_RATE=175

# Ventana horaria para publicar (1 video/día a hora aleatoria dentro del rango)
# Ej: MIN=18 MAX=22 → publica entre 18:00 y 22:59, hora distinta cada día
SCHEDULE_MIN_HOUR=18
SCHEDULE_MAX_HOUR=22

# ─── Debug ────────────────────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
