# ─── Shorts Factory — Variables de entorno ───────────────────────────────────
# Copiar este archivo a .env y rellenar los valores reales
# NUNCA subir .env a git (ya está en .gitignore)

# ════════════════════════════════════════════════════════════════════════
# BLOQUE 1 — LLM (generación de guiones)
# ══════════════════════════════���═════════════════════════════════════════

# Groq: cloud gratuito, mucho más rápido que Ollama
# Regístrate gratis: https://console.groq.com
# Prioridad: Groq → OpenAI → Ollama (en ese orden si algo falla)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI: fallback de emergencia si Groq falla
# Dejar vacío para desactivar
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Ollama: LLM local (último recurso, sin internet ni API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_FALLBACK_MODEL=mistral:7b
OLLAMA_TIMEOUT=600

# ═════════════════════════════════════════════��══════════════════════════
# BLOQUE 2 — YouTube
# ═════════════════════════════════════════════════���══════════════════════

# Credenciales de la cuenta (usadas por Selenium/nodriver)
YOUTUBE_EMAIL=tucorreo@gmail.com
YOUTUBE_PASSWORD=tu_password_aqui

# Activar subida real a YouTube (false = solo genera el video, no sube)
YOUTUBE_UPLOAD_ENABLED=false

# YouTube Data API v3 (gratis en console.cloud.google.com)
# Necesaria para el Viral Monitor y analytics detallados
# Sin esta key el analista usa scraping — funciona igual pero con menos detalle
YOUTUBE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ══════════════════════════��══════════════════════════════════���══════════
# BLOQUE 3 — TikTok
# ════════════════════════════════════════════════════════════════════���═══

TIKTOK_UPLOAD_ENABLED=false
TIKTOK_USERNAME=@tu_usuario_tiktok

# ════════════════════════════════════════════════════════════��═══════════
# BLOQUE 4 — Telegram (notificaciones y aprobación manual)
# ══════════════════════════════════════════════════════════════════��═════

# Cómo crear el bot: habla con @BotFather en Telegram → /newbot
TELEGRAM_BOT_TOKEN=7845xxxxxx:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Tu chat_id personal: habla con @userinfobot en Telegram
TELEGRAM_CHAT_ID=123456789

# Aprobación manual antes de publicar en YouTube
# true = el pipeline pausa y espera tu ✅/❌ en Telegram
TELEGRAM_APPROVAL_ENABLED=false
# Segundos máximos esperando respuesta (7200 = 2 horas)
TELEGRAM_APPROVAL_TIMEOUT=7200
# Veces máximas que se regenera un video nuevo cuando se rechaza
MAX_WA_RETRIES=3

# Canal público de Telegram para publicar confesiones
# ID del canal (ej: @micanal o -100123456789)
# El bot debe ser admin con permisos de publicación
TELEGRAM_CHANNEL_ID=@micanal
# Link público del canal (para CTAs en YouTube y TikTok)
TELEGRAM_CHANNEL_LINK=https://t.me/micanal
# Precio en Stars para contenido premium (50-100 recomendado)
TELEGRAM_CHANNEL_STARS=50
# Cuántas confesiones publicar en el canal por día
TELEGRAM_CHANNEL_DAILY=4

# ══════════════════════════════════════════════════��═════════════════════
# BLOQUE 5 — Pexels (stock videos)
# ══════════════════════════════════════════��═════════════════════════════

# Pexels (fuente primaria) — Regístrate gratis: https://www.pexels.com/api/
# 200 solicitudes/hora, 20,000/mes — suficiente para el pipeline
PEXELS_API_KEY=tu_clave_pexels_aqui

# Pixabay (fuente secundaria — CC0, sin Content ID de YouTube)
# Se activa automáticamente cuando Pexels no tiene clips frescos.
# Registrate gratis: https://pixabay.com/api/docs/ (hasta 100 req/min)
# MUY RECOMENDADO para reducir el riesgo de flag "reused content".
PIXABAY_API_KEY=tu_clave_pixabay_aqui

# ═════════════════════���══════════════════════════════════════════════════
# BLOQUE 6 — Branding del canal
# ════════════════════════════════════════════��═══════════════════════════

CHANNEL_NAME=GATA CURIOSA

# Pie de afiliado en descripción (dejar vacío para desactivar)
# Ejemplo: "🔗 Créditos con estos links: https://..."
AFFILIATE_FOOTER=

# ═════════════════════════��═══════════════════════════════════���══════════
# BLOQUE 7 — Video y TTS
# ══════════════════════════════════════════════════════════════════��═════

# Velocidad de la voz narradora (palabras por minuto)
# 150=lento y dramático | 175=natural (default) | 200=rápido
TTS_VOICE_RATE=175

# Backend de TTS: "edge" (Edge TTS neural, gratis) | "pyttsx3" (100% offline)
TTS_BACKEND=edge

# Threads de CPU para Whisper (alineación de subtítulos)
# 1 = seguro para laptops (evita CLOCK_WATCHDOG_TIMEOUT BSOD)
# 2 = solo si tienes buena refrigeración
WHISPER_CPU_THREADS=1

# Volumen de la música de fondo (0.0–1.0)
MUSIC_VOLUME=0.13

# Cortes por escena — número de clips distintos a concatenar dentro de cada escena
# 1 = un solo clip (comportamiento anterior)
# 2 = dos clips con Ken Burns alternado (recomendado — ritmo TikTok sin sobrecargar CPU)
# 3 = tres clips (edición muy activa — requiere más ancho de banda para descargar clips)
CUTS_PER_SCENE=2

# Tamaño y posición de subtítulos
SUBTITLE_FONT_SIZE=88
# Distancia del subtítulo desde el borde inferior (px en resolución 1920px)
# 1000 → ~48% desde arriba (centro-alto, estilo CapCut viral)
# 800  → ~58% desde arriba (más abajo)
# 1200 → ~37% desde arriba (más arriba)
SUBTITLE_MARGIN_V=1000

# ══════════════════════════════════════════════════════════���═════════════
# BLOQUE 8 — Scheduler
# ════════════════════════════════════════════════════════════════════════

# Videos por día (se distribuyen en 3 ventanas horarias)
VIDEOS_PER_DAY=3

# Antigüedad del canal en semanas — controla la rampa de publicación:
#   1-2 semanas → 1 video/día (no levantar alertas en canal nuevo)
#   3-4 semanas → 2 videos/día
#   5+ semanas  → VIDEOS_PER_DAY completo
# Incrementa este valor manualmente cada semana.
CHANNEL_AGE_WEEKS=1

# Ventanas de audiencia pico (hora latinoamericana)
# WIN1: almuerzo | WIN2: tarde | WIN3: noche
SCHEDULE_WIN1_MIN=11
SCHEDULE_WIN1_MAX=13
SCHEDULE_WIN2_MIN=16
SCHEDULE_WIN2_MAX=18
SCHEDULE_WIN3_MIN=20
SCHEDULE_WIN3_MAX=22

# Hora del reporte diario de analytics (0-23)
ANALYTICS_HOUR=9
# Activar analytics diarios (true/false)
ANALYTICS_ENABLED=true

# ════════════════════════════════════════════════════════════════════════
# BLOQUE 9 — Growth Agent
# ═════════════════════════════════════════════���══════════════════════════

# Límites diarios de comentarios (ajusta según madurez del canal)
# Canal nuevo (<1K subs): puedes subir a 10/5/4 sin riesgo real
# Canal maduro (>10K subs): mantener en 5/2/2 para evitar filtros
GROWTH_DAILY_EXTERNAL_LIMIT=5
GROWTH_DAILY_OWN_LIMIT=2
GROWTH_SESSION_EXTERNAL_CAP=2
# Vistas mínimas del video para comentar en él
GROWTH_MIN_VIDEO_VIEWS=50000

# ═════════════════════════���══════════════════════════════════���═══════════
# BLOQUE 10 — Calidad y analytics
# ════════════════════════════════════════════════════════════════════════

# Score mínimo para publicar un guion (1-10)
# Si el guion queda por debajo, se regenera (hasta 2 reintentos)
SCRIPT_MIN_SCORE=7

# Cuántos snapshots de analytics guardar en historial (~60 = 2 meses)
ANALYTICS_MAX_SNAPSHOTS=60
ANALYTICS_TOP_VIDEOS_DETAIL=3

# Umbral de vistas en 30 min para activar alerta viral
VIRAL_THRESHOLD=300

# ════════════════════════════════════════════════════════════════════════
# BLOQUE 11 — Debug
# ═════════════════════════════════════════════════��══════════════════════

# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
